NODE_ENV=development
PORT=3333

# OBRIGATÓRIO: gere valores aleatórios fortes, nunca reutilize estes exemplos.
# Sugestão para ambos: openssl rand -hex 32
JWT_SECRET=GERE_UM_VALOR_ALEATORIO_DE_NO_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=2h

# OBRIGATÓRIO: usado para criptografar o segredo de MFA em repouso (AES-256-GCM).
# Trocar esta chave depois que houver MFA ativo torna os segredos ilegíveis.
ENCRYPTION_KEY=GERE_OUTRO_VALOR_ALEATORIO_DE_NO_MINIMO_32_CARACTERES

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tech4um

# Redis - usado pela blacklist distribuida de tokens (logout/revogacao)
REDIS_URL=redis://localhost:6379

# OBRIGATÓRIO em produção (sem fallback para "*")
CORS_ORIGIN=http://localhost:5173

# URL pública do frontend (usada nos links do e-mail de verificação)
FRONTEND_URL=http://localhost:5173

# Login com Google
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com

# CAPTCHA - Cloudflare Turnstile (OBRIGATÓRIO em produção)
# Crie em https://dash.cloudflare.com/?to=/:account/turnstile
# Em DEV, pode usar a chave de teste pública "always passes":
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=

# SMTP para envio do e-mail de verificação (OBRIGATÓRIO em produção)
# Na Hostinger: host smtp.hostinger.com, porta 465 (SSL) ou 587 (TLS)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Tech4um <no-reply@seudominio.com>
