NODE_ENV=development
PORT=3333

# OBRIGATÓRIO: gere valores aleatórios fortes, nunca reutilize estes exemplos.
# Sugestão para ambos: openssl rand -hex 32
JWT_SECRET=GERE_UM_VALOR_ALEATORIO_DE_NO_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=2h

# OBRIGATÓRIO: usado para criptografar o segredo de MFA em repouso (AES-256-GCM).
# Trocar esta chave depois que houver MFA ativo torna os segredos ilegíveis.
ENCRYPTION_KEY=GERE_OUTRO_VALOR_ALEATORIO_DE_NO_MINIMO_32_CARACTERES

# Alinhado com docker-compose.infra.yml (subido automaticamente via pnpm dev)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tech4um

# Redis - blacklist de tokens (logout). Senha deve bater com REDIS_PASSWORD na raiz.
REDIS_URL=redis://:redis_dev_local@localhost:6379

# OBRIGATÓRIO em produção (sem fallback para "*")
CORS_ORIGIN=http://localhost:5173

# URL pública do frontend (usada nos links do e-mail de verificação)
FRONTEND_URL=http://localhost:5173

# Login com Google — use o MESMO Client ID no backend (GOOGLE_CLIENT_ID) e no frontend (VITE_GOOGLE_CLIENT_ID).
# No Google Cloud Console (tipo "Aplicativo da Web"), configure:
#   Origens JavaScript autorizadas: http://localhost:5173
#   URIs de redirecionamento autorizados: http://localhost:5173
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# CAPTCHA - Google reCAPTCHA v3 (OBRIGATÓRIO em produção)
# Crie em https://www.google.com/recaptcha/admin (tipo: reCAPTCHA v3)
# Use o par site key (frontend) + secret key (backend) do MESMO site
RECAPTCHA_SECRET_KEY=
# Score mínimo aceito (0.0 a 1.0). Padrão: 0.5
RECAPTCHA_MIN_SCORE=0.5

# SMTP para envio do e-mail de verificação (OBRIGATÓRIO em produção)
# Na Hostinger: host smtp.hostinger.com, porta 465 (SSL) ou 587 (TLS)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Tech4um <no-reply@seudominio.com>

# Seed automático de salas demo na 1ª execução (banco vazio). Padrão: true em dev, false em produção.
# SEED_DEMO_DATA=false
