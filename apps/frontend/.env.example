# Em dev, use /api com proxy do Vite (mesma origem → cookie httpOnly funciona).
VITE_API_URL=/api
# Opcional em dev: omita para usar window.location.origin (proxy /socket.io no Vite).
# VITE_SOCKET_URL=
# Login com Google — MESMO Client ID do GOOGLE_CLIENT_ID no backend.
# No Google Cloud Console (tipo "Aplicativo da Web"), configure:
#   Origens JavaScript autorizadas: http://localhost:5173
#   URIs de redirecionamento autorizados: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com

# CAPTCHA - site key PÚBLICA do Google reCAPTCHA v3
# Crie em https://www.google.com/recaptcha/admin (tipo: reCAPTCHA v3)
VITE_RECAPTCHA_SITE_KEY=
