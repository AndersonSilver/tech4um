# Copie para .env na VPS: cp .env.production.example .env
# Nunca commite o .env real.

# ---- Portas locais (só localhost — o Nginx do host faz o HTTPS) ----
TECH4UM_FRONTEND_PORT=8173
TECH4UM_BACKEND_PORT=8174

# ---- Segredos (gere com: openssl rand -hex 32) ----
JWT_SECRET=
DB_PASSWORD=
REDIS_PASSWORD=

# ---- Domínio público (mesmo host para front + API + WebSocket) ----
# Ex.: https://tech4um.seudominio.com
CORS_ORIGIN=https://tech4um.seudominio.com
FRONTEND_URL=https://tech4um.seudominio.com
VITE_API_URL=https://tech4um.seudominio.com/api
VITE_SOCKET_URL=https://tech4um.seudominio.com

# ---- Google OAuth (mesmo Client ID no front e back) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- reCAPTCHA v3 ----
RECAPTCHA_SECRET_KEY=
VITE_RECAPTCHA_SITE_KEY=

# ---- SMTP Hostinger ----
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@seudominio.com
SMTP_PASSWORD=
SMTP_FROM=Tech4um <no-reply@seudominio.com>

# ---- Primeiro deploy apenas: cria tabelas no Postgres vazio ----
# Depois que subir OK, mude para false e redeploy.
TYPEORM_SYNC_ONCE=true

# ---- Demo (opcional): 15 salas na 1ª execução ----
SEED_DEMO_DATA=true
