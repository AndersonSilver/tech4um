# Nginx no HOST (VPS) — um subdomínio para o Tech4um.
# O frontend Docker (8173) repassa /api e /socket.io ao backend internamente.
#
# Copie para /etc/nginx/sites-available/tech4um e ative com certbot.
# Ajuste server_name e TECH4UM_FRONTEND_PORT se mudou no .env (padrão 8173).

upstream tech4um_app {
    server 127.0.0.1:8173;
}

server {
    listen 80;
    server_name tech4um.seudominio.com;

    location / {
        proxy_pass http://tech4um_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
        client_max_body_size 16m;
    }

    # certbot --nginx -d tech4um.seudominio.com
}
